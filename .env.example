# Copy to `.env` and fill in your key:
#   cp .env.example .env
#
# OpenAI — image generation (Images API / DALL·E 3). Used only by:
#   npm run generate:images
OPENAI_API_KEY=

# Optional: only if you must read a secret from Vite *client* code (the value is
# still bundled — prefer a small backend or serverless function that uses
# OPENAI_API_KEY and never exposes it to the browser).
# VITE_OPENAI_API_KEY=
